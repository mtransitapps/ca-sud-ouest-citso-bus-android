{
    "default_route_id_enabled": true,
    "use_route_short_name_for_route_id": true,
    "route_short_name_cleaners": [
        {
            "regex": "(^t(-))",
            "ignore_case": true,
            "replacement": "T"
        }
    ],
    "default_route_long_name_enabled": true,
    "direction_finder_enabled": true,
    "direction_finder_disabled_until": {
        "111": "20260423"
    },
    "trip_id_cleanup_regex": "SO\\-\\w{1}\\d{2}\\-(SO_GTFS)\\-",
    "trip_id_cleanup_regex_comment": "remove trip ID shared by all trip IDs (include season letter and YY year)",
    "trip_headsign_cleaners": [
        {
            "regex": "express",
            "ignore_case": true,
            "is_word": true
        },
        {
            "regex": "( - )",
            "replacement": "<>",
            "replacement_comment": "save 1 ' ' character"
        }
    ],
    "stop_name_cleaners": [
        {
            "regex": "( - )",
            "replacement": " ",
            "replacement_comment": "save 2 characters"
        },
        {
            "regex": "devant",
            "ignore_case": true,
            "is_word": true
        }
    ],
    "use_stop_id_for_stop_code": true,
    "use_stop_code_for_stop_id": true
}
